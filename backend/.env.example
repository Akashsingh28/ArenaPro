# Copy this file to .env and fill in your values

PORT=5000

# MongoDB connection string
# Option 1 – Local MongoDB (make sure MongoDB is installed and running)
MONGO_URI=mongodb://localhost:27017/arenapro

# Option 2 – MongoDB Atlas (cloud, free tier available at https://cloud.mongodb.com)
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/arenapro?retryWrites=true&w=majority

# JWT Settings
JWT_SECRET=change_this_to_a_random_long_secret_string_at_least_32_chars
JWT_EXPIRE=7d
